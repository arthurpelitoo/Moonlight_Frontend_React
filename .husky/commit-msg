#!/bin/sh
commit_msg=$(cat "$1")
pattern="^(feat|fix|chore|docs|refactor|test|hotfix)(\(.+\))?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Mensagem de commit inválida!"
  echo "   Use o formato: tipo(escopo?): descrição"
  echo "   Tipos válidos: feat, fix, chore, docs, refactor, test, hotfix"
  echo "   Exemplo: feat: adiciona tela de login"
  echo ""
  exit 1
fi
